#!/bin/bash
# Hunter OS Welcome Screen

# Check if already shown
if [ -f ~/.config/hunter-os/welcome-shown ]; then
    exit 0
fi

zenity --info \
  --title="Welcome to Hunter OS" \
  --width=600 \
  --height=400 \
  --text="<big><b>Hunter OS - Security-Focused Linux Distribution</b></big>

<b>Security Status:</b>
• Firewall: Active (UFW - deny all inbound)
• Intrusion Prevention: Active (Fail2Ban)
• AppArmor: Enabled
• SSH: Hardened (key-only, not auto-started)

<b>User Isolation (Windows/macOS model):</b>
• Home directories are private (only you can access yours)
• Other users cannot see your files or processes
• Use /home/Shared to share files between accounts
• Default umask: 077 (new files are private)

<b>Package Management:</b>
• <tt>hunter install &lt;package&gt;</tt> - Install software
• <tt>hunter remove &lt;package&gt;</tt> - Remove software
• <tt>hunter update</tt> - Update system
• <tt>hunter status</tt> - Check security status

<b>Default Live Credentials:</b>
Username: <tt>hunter</tt>  Password: <tt>hunter</tt>
(Change immediately after installation!)

<b>Quick Start:</b>
• Firefox, Dolphin, Konsole ready to use
• <tt>hunter audit</tt> - Full security audit
• <tt>hunter firewall status</tt> - Check firewall"

# Don't show again
mkdir -p ~/.config/hunter-os
touch ~/.config/hunter-os/welcome-shown
