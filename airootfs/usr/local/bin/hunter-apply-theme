#!/bin/bash
# Hunter OS Theme Application Script
# Applies the premium macOS-like dark theme to KDE Plasma 6
# Runs on first login or can be called manually with --force

# Skip if already applied (don't overwrite user customizations)
MARKER="$HOME/.config/hunter-os/theme-applied"
if [ -f "$MARKER" ] && [ "$1" != "--force" ]; then
    exit 0
fi

echo ">>> Applying Hunter OS premium theme..."

# ─── Kvantum Theme ──────────────────────────────────────
if command -v kvantummanager &> /dev/null; then
    kvantummanager --set BreezeDark 2>/dev/null || true
    echo "✓ Kvantum theme set"
fi

# ─── KDE Color Scheme ──────────────────────────────────
if command -v plasma-apply-colorscheme &> /dev/null; then
    plasma-apply-colorscheme BreezeDark 2>/dev/null || true
    echo "✓ Color scheme applied"
fi

# ─── Desktop Theme ─────────────────────────────────────
if command -v plasma-apply-desktoptheme &> /dev/null; then
    plasma-apply-desktoptheme breeze-dark 2>/dev/null || true
    echo "✓ Desktop theme applied"
fi

# ─── Icon Theme (Papirus Dark — clean, macOS-like) ─────
if [ -d /usr/share/icons/Papirus-Dark ]; then
    # Set via plasma-changeicons if available
    if command -v plasma-changeicons &> /dev/null; then
        plasma-changeicons Papirus-Dark 2>/dev/null || true
    fi
    # Also set in kdeglobals directly
    kwriteconfig6 --file kdeglobals --group Icons --key Theme "Papirus-Dark" 2>/dev/null || true
    echo "✓ Papirus Dark icons applied"
fi

# ─── Cursor Theme ──────────────────────────────────────
if [ -d /usr/share/icons/breeze_cursors ]; then
    mkdir -p "$HOME/.icons/default"
    cat > "$HOME/.icons/default/index.theme" << 'EOF'
[Icon Theme]
Inherits=breeze_cursors
EOF
    kwriteconfig6 --file kcminputrc --group Mouse --key cursorTheme "breeze_cursors" 2>/dev/null || true
    echo "✓ Cursor theme set"
fi

# ─── Wallpaper ─────────────────────────────────────────
if command -v plasma-apply-wallpaperimage &> /dev/null; then
    if [ -f /usr/share/backgrounds/hunter-os-dark.png ]; then
        plasma-apply-wallpaperimage /usr/share/backgrounds/hunter-os-dark.png 2>/dev/null || true
    elif [ -f /usr/share/backgrounds/hunter-os.png ]; then
        plasma-apply-wallpaperimage /usr/share/backgrounds/hunter-os.png 2>/dev/null || true
    fi
    echo "✓ Wallpaper applied"
fi

# ─── GTK Theme (for GTK apps running on KDE) ──────────
mkdir -p "$HOME/.config/gtk-3.0"
cat > "$HOME/.config/gtk-3.0/settings.ini" << 'EOF'
[Settings]
gtk-application-prefer-dark-theme=true
gtk-theme-name=Breeze-Dark
gtk-icon-theme-name=Papirus-Dark
gtk-cursor-theme-name=breeze_cursors
gtk-font-name=Noto Sans 10
gtk-cursor-theme-size=24
gtk-decoration-layout=close,minimize,maximize:
EOF

mkdir -p "$HOME/.config/gtk-4.0"
cat > "$HOME/.config/gtk-4.0/settings.ini" << 'EOF'
[Settings]
gtk-application-prefer-dark-theme=true
gtk-theme-name=Breeze-Dark
gtk-icon-theme-name=Papirus-Dark
gtk-cursor-theme-name=breeze_cursors
gtk-font-name=Noto Sans 10
gtk-cursor-theme-size=24
gtk-decoration-layout=close,minimize,maximize:
EOF

echo "✓ GTK theme configured (dark mode + Papirus icons)"

# ─── KWin Effects (ensure blur + animations active) ────
kwriteconfig6 --file kwinrc --group Plugins --key blurEnabled true 2>/dev/null || true
kwriteconfig6 --file kwinrc --group Plugins --key magiclampEnabled true 2>/dev/null || true
kwriteconfig6 --file kwinrc --group Plugins --key overviewEnabled true 2>/dev/null || true
kwriteconfig6 --file kwinrc --group Plugins --key diminactiveEnabled true 2>/dev/null || true
kwriteconfig6 --file kwinrc --group Compositing --key Backend OpenGL 2>/dev/null || true
echo "✓ KWin effects configured"

# ─── Night Color (blue light filter) ──────────────────
kwriteconfig6 --file kwinrc --group NightColor --key Active true 2>/dev/null || true
kwriteconfig6 --file kwinrc --group NightColor --key NightTemperature 4200 2>/dev/null || true
echo "✓ Night Color enabled"

# ─── Reload KWin to apply effects ─────────────────────
if [ -n "$DISPLAY" ] || [ -n "$WAYLAND_DISPLAY" ]; then
    qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null || true
fi

# Mark as applied
mkdir -p "$HOME/.config/hunter-os"
touch "$MARKER"

echo ">>> Hunter OS premium theme applied!"
echo ">>> To re-apply: hunter-apply-theme --force"
