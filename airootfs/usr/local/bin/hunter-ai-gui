#!/usr/bin/env python3
import gi
import subprocess
import threading
import os
import signal

gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, Gdk, GLib, Pango

class HunterAIGUI(Gtk.Window):
    def __init__(self):
        super().__init__(title="Hunter AI Assistant")
        self.set_default_size(500, 700)
        self.set_border_width(10)
        self.set_position(Gtk.WindowPosition.CENTER)
        
        # Header Bar
        header = Gtk.HeaderBar()
        header.set_show_close_button(True)
        header.set_title("Hunter AI")
        header.set_subtitle("Powered by Qwen2.5-Coder")
        self.set_titlebar(header)
        
        # Main Layout
        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        self.add(vbox)
        
        # Chat History Area
        self.scrolled_window = Gtk.ScrolledWindow()
        self.scrolled_window.set_hexpand(True)
        self.scrolled_window.set_vexpand(True)
        self.scrolled_window.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
        vbox.pack_start(self.scrolled_window, True, True, 0)
        
        self.text_view = Gtk.TextView()
        self.text_view.set_editable(False)
        self.text_view.set_cursor_visible(False)
        self.text_view.set_wrap_mode(Gtk.WrapMode.WORD)
        self.text_view.set_left_margin(10)
        self.text_view.set_right_margin(10)
        self.text_view.set_top_margin(10)
        self.text_view.set_bottom_margin(10)
        
        # Tags for styling
        self.buffer = self.text_view.get_buffer()
        self.buffer.create_tag("user", weight=Pango.Weight.BOLD, foreground="#00e5ff") # Cyan
        self.buffer.create_tag("ai", foreground="#ffffff")
        self.buffer.create_tag("system", style=Pango.Style.ITALIC, foreground="#888888")
        self.buffer.create_tag("code", font="Monospace 10", background="#2d2d2d")
        
        self.scrolled_window.add(self.text_view)
        
        # Input Area
        input_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=5)
        vbox.pack_start(input_box, False, False, 0)
        
        self.entry = Gtk.Entry()
        self.entry.set_placeholder_text("Ask about coding, security, or Linux...")
        self.entry.connect("activate", self.on_send)
        input_box.pack_start(self.entry, True, True, 0)
        
        self.send_btn = Gtk.Button(label="Send")
        self.send_btn.connect("clicked", self.on_send)
        context = self.send_btn.get_style_context()
        context.add_class('suggested-action')
        input_box.pack_start(self.send_btn, False, False, 0)
        
        # Status Bar
        self.spinner = Gtk.Spinner()
        self.status_label = Gtk.Label(label="Ready")
        self.status_label.set_halign(Gtk.Align.START)
        
        status_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=5)
        status_box.pack_start(self.spinner, False, False, 0)
        status_box.pack_start(self.status_label, False, False, 0)
        vbox.pack_start(status_box, False, False, 0)
        
        # Welcome Message
        self.append_message("System", "Welcome to Hunter AI. I can help you with penetration testing commands, coding scripts, and system troubleshooting.", "system")
        
        # Process handling
        self.process = None
        self.running = False
        
    def append_message(self, sender, text, tag):
        end_iter = self.buffer.get_end_iter()
        self.buffer.insert_with_tags_by_name(end_iter, f"\n{sender}: ", tag)
        self.buffer.insert(end_iter, f"\n{text}\n")
        
        # Auto-scroll
        adj = self.scrolled_window.get_vadjustment()
        GLib.idle_add(adj.set_value, adj.get_upper() - adj.get_page_size())
        
    def on_send(self, widget):
        text = self.entry.get_text().strip()
        if not text:
            return
            
        self.entry.set_text("")
        self.append_message("You", text, "user")
        self.set_busy(True)
        
        # Run in thread
        thread = threading.Thread(target=self.query_llm, args=(text,))
        thread.daemon = True
        thread.start()
        
    def set_busy(self, busy):
        self.entry.set_sensitive(not busy)
        self.send_btn.set_sensitive(not busy)
        if busy:
            self.spinner.start()
            self.status_label.set_text("Thinking...")
        else:
            self.spinner.stop()
            self.status_label.set_text("Ready")
            self.entry.grab_focus()

    def query_llm(self, prompt):
        try:
            # Call ollama CLI
            # Note: Interactive streaming is harder with Popen, getting full response for now
            # For better UX in V2, we'd use requests against localhost:11434 API
            
            # Simple CLI call (no streaming)
            result = subprocess.run(
                ['ollama', 'run', 'qwen2.5-coder:1.5b', prompt],
                capture_output=True,
                text=True,
                encoding='utf-8',
                errors='replace' # Handle potential encoding issues
            )
            
            if result.returncode == 0:
                response = result.stdout.strip()
            else:
                response = f"Error: {result.stderr}"
                
            GLib.idle_add(self.on_response_ready, response)
            
        except Exception as e:
            GLib.idle_add(self.on_response_ready, f"Error: {str(e)}")

    def on_response_ready(self, response):
        self.append_message("Hunter AI", response, "ai")
        self.set_busy(False)

if __name__ == "__main__":
    # Style styling
    css_provider = Gtk.CssProvider()
    css = b"""
    textview text {
        color: #eeeeee;
        background-color: #1e1e1e;
    }
    """
    css_provider.load_from_data(css)
    Gtk.StyleContext.add_provider_for_screen(
        Gdk.Screen.get_default(), css_provider,
        Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
    )
    
    win = HunterAIGUI()
    win.connect("destroy", Gtk.main_quit)
    win.show_all()
    Gtk.main()
