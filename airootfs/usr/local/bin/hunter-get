#!/bin/bash
# hunter-get: The HUNTER OS Package Manager Helper
# Makes installing complex tools easy for the user.

ACTION=$1
TARGET=$2

print_help() {
    echo "HUNTER OS Package Helper"
    echo "Usage: hunter-get [install|fix] [package]"
    echo ""
    echo "Development Tools:"
    echo "  install dev-c       Install C/C++ Compilers (GCC, Make, CMake)"
    echo "  install dev-web     Install Web Tools (NodeJS, NPM, Yarn)"
    echo "  install dev-rust    Install Rust Toolchain"
    echo "  install dev-python  Install Python Development Tools"
    echo ""
    echo "Security Tools:"
    echo "  install security-audit    Install Security Auditing Tools"
    echo "  install pentest           Install Penetration Testing Tools"
    echo ""
    echo "System Fixes:"
    echo "  fix wifi            Reset Wi-Fi Adapter"
    echo "  fix bluetooth       Reset Bluetooth Service"
    echo "  fix permissions     Reset System Permissions"
}

install_group() {
    echo ">>> HUNTER-GET: Installing $1..."
    sudo pacman -S --noconfirm --needed "$2"
}

enable_multilib() {
    if ! grep -q '\[multilib\]' /etc/pacman.conf; then
        echo -e '\n[multilib]\nInclude = /etc/pacman.d/mirrorlist' | sudo tee -a /etc/pacman.conf > /dev/null
        sudo pacman -Sy --noconfirm
        echo ">>> Multilib repository enabled."
    fi
}

case "$ACTION" in
    install)
        case "$TARGET" in
            dev-c|cpp|c++)
                install_group "C/C++ Dev Tools" "base-devel cmake gdb valgrind clang"
                ;;
            dev-web|node|nodejs)
                install_group "Web Dev Tools" "nodejs npm"
                ;;
            dev-python)
                install_group "Python Dev Tools" "python-pip python-virtualenv tk"
                ;;
            dev-rust)
                echo ">>> Installing Rust via rustup..."
                if command -v rustup &>/dev/null; then
                    rustup default stable
                    echo "Rust toolchain installed via rustup."
                else
                    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
                    echo "Rust installed. Run 'source ~/.cargo/env' to use it."
                fi
                ;;
            gaming)
                echo ">>> Enabling Multilib and installing gaming tools..."
                enable_multilib
                install_group "Gaming Essentials" "steam lutris gamemode"
                ;;
            security-audit|sec-audit)
                echo ">>> Installing Security Audit Tools..."
                install_group "Security Audit Tools" "lynis rkhunter"
                echo "NOTE: For additional tools, install from AUR with:"
                echo "  yay -S aide   (file integrity monitor)"
                ;;
            pentest|penetration)
                install_group "Penetration Testing Tools" "nmap wireshark-cli tcpdump"
                echo "NOTE: metasploit is AUR-only. Install with:"
                echo "  yay -S metasploit"
                ;;
            *)
                echo "Invoking Pacman for '$TARGET'..."
                sudo pacman -S --needed "$TARGET"
                ;;
        esac
        ;;
    fix)
        case "$TARGET" in
            wifi|internet)
                echo ">>> Resetting Network Manager..."
                sudo systemctl restart NetworkManager
                echo "Done."
                ;;
            bluetooth|bt)
                echo ">>> Resetting Bluetooth..."
                sudo rfkill unblock bluetooth
                sudo systemctl restart bluetooth
                echo "Done."
                ;;
            permissions|perms)
                echo ">>> Resetting System Permissions..."
                sudo chmod 700 /root
                sudo chmod 755 /usr/local/bin/hunter
                sudo chmod 755 /usr/local/bin/hunter-get
                sudo chmod 755 /etc/ssh/sshd_config.d
                # Ensure all home directories are private
                for dir in /home/*/; do
                    [ -d "$dir" ] && sudo chmod 700 "$dir"
                done
                echo "System permissions reset."
                ;;
            *)
                print_help
                ;;
        esac
        ;;
    *)
        print_help
        ;;
esac
