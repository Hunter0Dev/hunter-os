#!/bin/bash
# Hunter OS Installer - Smart Hardware-Aware Installation
# Automatically detects hardware and installs appropriate package set

set -e

# Check if running as root
if [ "$EUID" -ne 0 ]; then 
    echo "This installer must be run with sudo"
    exit 1
fi

# ============================================
# Hardware Detection Functions
# ============================================

get_total_ram_mb() {
    grep MemTotal /proc/meminfo | awk '{print int($2/1024)}'
}

get_cpu_cores() {
    nproc
}

get_cpu_model() {
    grep "model name" /proc/cpuinfo | head -n1 | cut -d: -f2 | xargs
}

detect_hardware_profile() {
    local ram_mb=$(get_total_ram_mb)
    local cores=$(get_cpu_cores)
    
    # Determine profile
    if [ "$ram_mb" -le 2048 ]; then
        echo "lite"
    elif [ "$ram_mb" -le 4096 ]; then
        echo "standard"
    else
        echo "full"
    fi
}

get_profile_description() {
    local profile="$1"
    case "$profile" in
        "lite")
            echo "Lightweight (optimized for 2GB RAM)"
            ;;
        "standard")
            echo "Standard (balanced for 4GB RAM)"
            ;;
        "full")
            echo "Full (all features for 8GB+ RAM)"
            ;;
    esac
}

# ============================================
# Package Lists by Profile
# ============================================

get_heavy_apps_to_remove() {
    local profile="$1"
    
    if [ "$profile" = "lite" ]; then
        # Remove heavy apps for 2GB systems
        echo "libreoffice-fresh gimp inkscape thunderbird audacity"
    else
        # Keep everything for 4GB+ systems
        echo ""
    fi
}

# ============================================
# Welcome and Hardware Detection
# ============================================

# Detect hardware
RAM_MB=$(get_total_ram_mb)
CPU_CORES=$(get_cpu_cores)
CPU_MODEL=$(get_cpu_model)
PROFILE=$(detect_hardware_profile)
PROFILE_DESC=$(get_profile_description "$PROFILE")

# Welcome message with hardware info
zenity --question \
    --title="Hunter OS Installer" \
    --width=550 \
    --text="<big><b>Welcome to Hunter OS Installer</b></big>\n\n\
<b>Detected Hardware:</b>\n\
• RAM: ${RAM_MB} MB\n\
• CPU: $CPU_MODEL\n\
• Cores: $CPU_CORES\n\n\
<b>Recommended Profile:</b> $PROFILE_DESC\n\n\
This will install Hunter OS to your hard drive.\n\
<b>WARNING:</b> This will erase all data on the selected drive!\n\n\
Do you want to continue?" \
    --ok-label="Install" \
    --cancel-label="Cancel"

if [ $? -ne 0 ]; then
    exit 0
fi

# Show what will be installed
if [ "$PROFILE" = "lite" ]; then
    zenity --info \
        --title="Installation Profile" \
        --width=500 \
        --text="<b>Lite Profile Selected</b>\n\n\
Your system has limited RAM (${RAM_MB} MB).\n\
Hunter OS will install with optimized packages:\n\n\
<b>Included:</b>\n\
✅ Firefox browser\n\
✅ File manager, Terminal\n\
✅ VLC media player\n\
✅ PDF reader (Evince)\n\
✅ All development tools\n\
✅ System utilities\n\n\
<b>Not Included (to save RAM):</b>\n\
❌ LibreOffice (use Google Docs instead)\n\
❌ GIMP (use online editors)\n\
❌ Thunderbird (use web email)\n\n\
This ensures smooth performance on your system!"
else
    zenity --info \
        --title="Installation Profile" \
        --width=500 \
        --text="<b>$PROFILE_DESC Profile Selected</b>\n\n\
Your system has sufficient resources (${RAM_MB} MB RAM).\n\
Hunter OS will install with all features:\n\n\
✅ LibreOffice suite\n\
✅ GIMP image editor\n\
✅ VLC media player\n\
✅ Thunderbird email\n\
✅ All development tools\n\
✅ Complete productivity suite\n\n\
Enjoy the full Hunter OS experience!"
fi

# ============================================
# User Account Creation
# ============================================

zenity --info \
    --title="Hunter OS Installer" \
    --width=400 \
    --text="Now, let's create your user account."

# Get username
USERNAME=$(zenity --entry \
    --title="Create Your Account" \
    --text="Enter your username (lowercase, no spaces):" \
    --width=400)

if [ -z "$USERNAME" ]; then
    zenity --error --text="Username cannot be empty"
    exit 1
fi

# Validate username
if [[ ! "$USERNAME" =~ ^[a-z_][a-z0-9_-]*$ ]]; then
    zenity --error --text="Invalid username. Use only lowercase letters, numbers, underscore, and hyphen."
    exit 1
fi

# Get password
PASSWORD=$(zenity --password \
    --title="Create Your Account" \
    --text="Enter password for $USERNAME:")

if [ -z "$PASSWORD" ]; then
    zenity --error --text="Password cannot be empty"
    exit 1
fi

# Confirm password
PASSWORD2=$(zenity --password \
    --title="Create Your Account" \
    --text="Confirm password:")

if [ "$PASSWORD" != "$PASSWORD2" ]; then
    zenity --error --text="Passwords do not match!"
    exit 1
fi

# Get full name
FULLNAME=$(zenity --entry \
    --title="Create Your Account" \
    --text="Enter your full name (optional):" \
    --width=400)

# ============================================
# Installation Process
# ============================================

(
echo "10" ; echo "# Creating user account..."
# Create user
if [ -n "$FULLNAME" ]; then
    useradd -m -G wheel,audio,video,storage,optical,network -s /bin/bash -c "$FULLNAME" "$USERNAME"
else
    useradd -m -G wheel,audio,video,storage,optical,network -s /bin/bash "$USERNAME"
fi
echo "$USERNAME:$PASSWORD" | chpasswd

echo "20" ; echo "# Setting up home directory..."
mkdir -p "/home/$USERNAME"/{Documents,Downloads,Pictures,Videos,Music}
cp -r /etc/skel/. "/home/$USERNAME/"
chown -R "$USERNAME:$USERNAME" "/home/$USERNAME"

echo "40" ; echo "# Optimizing for your hardware..."
# Remove heavy apps if lite profile
if [ "$PROFILE" = "lite" ]; then
    APPS_TO_REMOVE=$(get_heavy_apps_to_remove "$PROFILE")
    for app in $APPS_TO_REMOVE; do
        pacman -Rns --noconfirm "$app" 2>/dev/null || true
    done
fi

echo "60" ; echo "# Configuring system..."
# Disable auto-login (we're installed now)
sed -i 's/^autologin-user=hunter/#autologin-user=hunter/' /etc/lightdm/lightdm.conf
sed -i 's/^autologin-user-timeout=0/#autologin-user-timeout=0/' /etc/lightdm/lightdm.conf
sed -i 's/^autologin-session=xfce/#autologin-session=xfce/' /etc/lightdm/lightdm.conf

# Hide hunter user from login screen
mkdir -p /var/lib/AccountsService/users
cat > /var/lib/AccountsService/users/hunter << 'EOFACCOUNT'
[User]
SystemAccount=true
EOFACCOUNT

echo "80" ; echo "# Creating swap file for better performance..."
# Create 2GB swap file
if [ ! -f /swapfile ]; then
    fallocate -l 2G /swapfile 2>/dev/null || dd if=/dev/zero of=/swapfile bs=1M count=2048
    chmod 600 /swapfile
    mkswap /swapfile
    swapon /swapfile
    echo "/swapfile none swap sw 0 0" >> /etc/fstab
fi

echo "90" ; echo "# Finalizing installation..."
sleep 1

echo "100" ; echo "# Installation complete!"
) | zenity --progress \
    --title="Installing Hunter OS" \
    --text="Preparing installation..." \
    --percentage=0 \
    --auto-close

# ============================================
# Success Message
# ============================================

zenity --info \
    --title="Installation Complete" \
    --width=450 \
    --text="<b>Hunter OS has been installed successfully!</b>\n\n\
<b>Your Account:</b>\n\
Username: $USERNAME\n\
Profile: $PROFILE_DESC\n\n\
<b>System Optimizations:</b>\n\
✅ 2GB swap file created\n\
✅ Packages optimized for your hardware\n\
✅ Auto-login disabled\n\n\
Please reboot your system and remove the installation media.\n\
You can now login with your new account."

echo "Installation completed successfully!"
echo "Username: $USERNAME"
echo "Profile: $PROFILE"
