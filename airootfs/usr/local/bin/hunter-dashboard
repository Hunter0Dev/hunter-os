#!/usr/bin/env python3
"""Hunter OS Dashboard — Premium dark card-based welcome screen."""

import subprocess
import gi

gi.require_version("Gtk", "3.0")
from gi.repository import Gtk, Gdk, GLib

CSS = """
/* ═══════ Global ═══════ */
window {
    background-color: #0A0A0F;
}

headerbar {
    background-color: #0A0A0F;
    border-bottom: 1px solid #1E1E24;
    box-shadow: none;
    color: #FFFFFF;
    min-height: 36px;
    padding: 0 12px;
}

headerbar .title {
    color: #FFFFFF;
    font-weight: 300;
    font-size: 13px;
    letter-spacing: 3px;
}

/* ═══════ Welcome Text ═══════ */
.welcome-title {
    color: #FFFFFF;
    font-size: 28px;
    font-weight: 300;
    letter-spacing: -0.5px;
}

.welcome-subtitle {
    color: #6E6E80;
    font-size: 13px;
    font-weight: 400;
}

/* ═══════ Cards ═══════ */
.card {
    background-color: #111116;
    border-radius: 14px;
    border: 1px solid #1E1E24;
    padding: 20px;
    transition: 200ms ease;
}

.card:hover {
    border-color: #00BFFF;
    background-color: #161619;
}

.card-icon-box {
    background-color: #0A0A0F;
    border-radius: 10px;
    min-width: 40px;
    min-height: 40px;
}

.card-icon {
    color: #3A3A48;
    font-size: 18px;
}

.card:hover .card-icon {
    color: #00BFFF;
}

.card-label {
    color: #6E6E80;
    font-size: 13px;
    font-weight: 400;
}

.card:hover .card-label {
    color: #FFFFFF;
}

.card-desc {
    color: #3A3A48;
    font-size: 11px;
    font-weight: 400;
}

/* ═══════ Brand Mark ═══════ */
.brand-text {
    color: #3A3A48;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 3px;
}
"""

CARDS = [
    {
        "icon": "▶",
        "label": "Install OS",
        "desc": "Install Hunter OS to disk",
        "action": lambda: subprocess.Popen(["pkexec", "calamares"]),
    },
    {
        "icon": "◆",
        "label": "AI Assistant",
        "desc": "Built-in AI helper",
        "action": lambda: subprocess.Popen(["hunter-ai-gui"]),
    },
    {
        "icon": "◈",
        "label": "Documentation",
        "desc": "Guides and references",
        "action": lambda: subprocess.Popen(
            ["xdg-open", "/usr/share/doc/hunter-os/README.md"]
        ),
    },
    {
        "icon": "◎",
        "label": "Browse Web",
        "desc": "Open Firefox browser",
        "action": lambda: subprocess.Popen(["firefox"]),
    },
    {
        "icon": "▣",
        "label": "Terminal",
        "desc": "Konsole terminal emulator",
        "action": lambda: subprocess.Popen(["konsole"]),
    },
    {
        "icon": "◉",
        "label": "System Monitor",
        "desc": "Resource usage and processes",
        "action": lambda: subprocess.Popen(["plasma-systemmonitor"]),
    },
]


class HunterDashboard(Gtk.Window):
    def __init__(self):
        super().__init__(title="HUNTER OS")
        self.set_default_size(720, 520)
        self.set_position(Gtk.WindowPosition.CENTER)

        # Apply CSS
        provider = Gtk.CssProvider()
        provider.load_from_data(CSS.encode())
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(),
            provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
        )

        # Header bar
        header = Gtk.HeaderBar()
        header.set_show_close_button(True)
        header.set_title("HUNTER OS")
        self.set_titlebar(header)

        # Main vertical layout
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        outer.set_margin_start(48)
        outer.set_margin_end(48)
        outer.set_margin_top(36)
        outer.set_margin_bottom(36)
        self.add(outer)

        # Welcome heading
        title = Gtk.Label(label="Welcome to Hunter OS")
        title.get_style_context().add_class("welcome-title")
        title.set_halign(Gtk.Align.START)
        outer.pack_start(title, False, False, 0)

        subtitle = Gtk.Label(label="Select an action to get started")
        subtitle.get_style_context().add_class("welcome-subtitle")
        subtitle.set_halign(Gtk.Align.START)
        subtitle.set_margin_top(4)
        outer.pack_start(subtitle, False, False, 0)

        # Spacer
        spacer = Gtk.Box()
        spacer.set_size_request(-1, 32)
        outer.pack_start(spacer, False, False, 0)

        # Card grid — 3 columns x 2 rows
        grid = Gtk.Grid()
        grid.set_column_spacing(16)
        grid.set_row_spacing(16)
        grid.set_column_homogeneous(True)
        outer.pack_start(grid, True, True, 0)

        for i, card_data in enumerate(CARDS):
            card = self._make_card(card_data)
            col = i % 3
            row = i // 3
            grid.attach(card, col, row, 1, 1)

        # Bottom brand mark
        brand = Gtk.Label(label="HUNTER")
        brand.get_style_context().add_class("brand-text")
        brand.set_margin_top(24)
        outer.pack_end(brand, False, False, 0)

    def _make_card(self, data):
        """Build a single action card."""
        btn = Gtk.Button()
        btn.set_relief(Gtk.ReliefStyle.NONE)
        btn.get_style_context().add_class("card")
        btn.connect("clicked", lambda _w: data["action"]())

        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        box.set_margin_start(4)
        box.set_margin_end(4)
        box.set_margin_top(4)
        box.set_margin_bottom(4)

        # Icon in a box
        icon_frame = Gtk.Box()
        icon_frame.get_style_context().add_class("card-icon-box")
        icon_frame.set_size_request(40, 40)
        icon_frame.set_halign(Gtk.Align.START)

        icon = Gtk.Label(label=data["icon"])
        icon.get_style_context().add_class("card-icon")
        icon.set_halign(Gtk.Align.CENTER)
        icon.set_valign(Gtk.Align.CENTER)
        icon_frame.pack_start(icon, True, True, 0)
        box.pack_start(icon_frame, False, False, 0)

        # Label
        label = Gtk.Label(label=data["label"])
        label.get_style_context().add_class("card-label")
        label.set_halign(Gtk.Align.START)
        box.pack_start(label, False, False, 0)

        # Description
        desc = Gtk.Label(label=data["desc"])
        desc.get_style_context().add_class("card-desc")
        desc.set_halign(Gtk.Align.START)
        box.pack_start(desc, False, False, 0)

        btn.add(box)
        return btn


def main():
    win = HunterDashboard()
    win.connect("destroy", Gtk.main_quit)
    win.show_all()
    Gtk.main()


if __name__ == "__main__":
    main()
