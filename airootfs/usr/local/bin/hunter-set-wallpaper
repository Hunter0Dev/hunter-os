#!/bin/bash
# Set Hunter OS wallpaper for KDE Plasma

WALLPAPER_DARK="/usr/share/backgrounds/hunter-os-dark.png"
WALLPAPER_DEFAULT="/usr/share/backgrounds/hunter-os.png"

# Determine which wallpaper to use
if [ -f "$WALLPAPER_DARK" ]; then
    WALLPAPER_PATH="$WALLPAPER_DARK"
elif [ -f "$WALLPAPER_DEFAULT" ]; then
    WALLPAPER_PATH="$WALLPAPER_DEFAULT"
else
    echo "No Hunter OS wallpaper found."
    exit 1
fi

# Set wallpaper for KDE Plasma
if command -v plasma-apply-wallpaperimage &> /dev/null; then
    plasma-apply-wallpaperimage "$WALLPAPER_PATH" 2>/dev/null || true
    echo "✓ KDE Plasma wallpaper set"
fi

# Set wallpaper for SDDM login screen
if [ -f /etc/sddm.conf.d/hunter.conf ]; then
    echo "✓ SDDM uses theme wallpaper"
fi

echo "Hunter OS wallpaper set successfully!"
echo "Wallpaper: $WALLPAPER_PATH"
