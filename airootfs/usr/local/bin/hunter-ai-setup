#!/bin/bash
# Hunter AI Assistant - Setup Script
# Downloads and configures ollama with Qwen2.5-Coder model

set -e

echo "=== Hunter AI Assistant Setup ==="

# Download ollama binary with verification
echo "[1/4] Downloading ollama..."
OLLAMA_TMP=$(mktemp)
curl -fsSL https://ollama.com/download/ollama-linux-amd64 -o "$OLLAMA_TMP"

# Verify the download is a valid ELF binary (basic integrity check)
if ! file "$OLLAMA_TMP" | grep -q "ELF 64-bit"; then
    echo "ERROR: Downloaded file is not a valid Linux binary. Aborting."
    rm -f "$OLLAMA_TMP"
    exit 1
fi

mv "$OLLAMA_TMP" /usr/local/bin/ollama
chmod +x /usr/local/bin/ollama

# Create ollama user and directories
echo "[2/4] Setting up ollama service..."
useradd -r -s /bin/false -m -d /usr/share/ollama ollama || true
mkdir -p /usr/share/ollama/.ollama/models

# Download Qwen2.5-Coder 1.5B model
echo "[3/4] Downloading Qwen2.5-Coder model (~1 GB)..."
# This will be downloaded during ISO build
export OLLAMA_MODELS=/usr/share/ollama/.ollama/models

# Start ollama in background temporarily
/usr/local/bin/ollama serve > /dev/null 2>&1 &
OLLAMA_PID=$!
sleep 5

# Pull the model
/usr/local/bin/ollama pull qwen2.5-coder:1.5b

# Stop temporary ollama
kill $OLLAMA_PID 2>/dev/null || true

# Set permissions
chown -R ollama:ollama /usr/share/ollama

echo "[4/4] Creating systemd service..."
cat > /etc/systemd/system/ollama.service << 'EOF'
[Unit]
Description=Ollama Service
After=network-online.target

[Service]
ExecStart=/usr/local/bin/ollama serve
User=ollama
Group=ollama
Restart=always
RestartSec=3
Environment="OLLAMA_HOST=127.0.0.1:11434"
Environment="OLLAMA_MODELS=/usr/share/ollama/.ollama/models"

[Install]
WantedBy=default.target
EOF

# Enable service
systemctl enable ollama.service

echo "✓ Hunter AI Assistant installed successfully!"
echo "  Model: Qwen2.5-Coder 1.5B"
echo "  Usage: ollama run qwen2.5-coder:1.5b"
