# /etc/fstab: static file system information for HUNTER OS
#
# <file system> <mount point>   <type>  <options>       <dump>  <pass>

# tmpfs mounts with security options
# /tmp allows exec (needed by many apps including electron, build tools, installers)
tmpfs           /tmp            tmpfs   defaults,nodev,nosuid,mode=1777         0 0
# /dev/shm is locked down (no exec, no suid, no devices)
tmpfs           /dev/shm        tmpfs   defaults,nodev,nosuid,noexec            0 0
