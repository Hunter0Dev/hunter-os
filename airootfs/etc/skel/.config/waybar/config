[
{
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 4,
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": ["network", "battery", "pulseaudio", "tray"],

    "hyprland/workspaces": {
        "format": "<sub>{icon}</sub>",
        "format-icons": {
            "default": "",
            "active": "",
            "urgent": ""
        },
        "persistent_workspaces": {
             "*": 5
        }
    },
    "clock": {
        "format": "{:%a %b %d  %H:%M}",
        "tooltip": false
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-icons": ["", "", ""]
    }
},
{
    "layer": "top",
    "position": "bottom",
    "height": 48,
    "width": 100, 
    "margin-bottom": 10,
    "modules-center": ["wlr/taskbar"],
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 32,
        "on-click": "activate"
    }
}
]
